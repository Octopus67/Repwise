{
  "expo": {
    "name": "Repwise",
    "slug": "hypertrophy-os",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0B0F14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.octopuslabs.repwise",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Repwise needs camera access to take progress photos and scan food barcodes.",
        "NSPhotoLibraryUsageDescription": "Repwise needs photo library access to select progress photos.",
        "NSPhotoLibraryAddUsageDescription": "Repwise needs permission to save workout share cards to your photo library.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Repwise sends notifications for workout reminders, personal records, and weekly check-ins."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0F14"
      },
      "package": "com.octopuslabs.repwise",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Repwise to save workout share cards to your photo library.",
          "savePhotosPermission": "Allow Repwise to save workout share cards to your photo library."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.626243275639-sd7og2jmth1018gtj6eha858o262hf24"
        }
      ],
      "expo-apple-authentication",
      "lottie-react-native"
    ],
    "scheme": "repwise",
    "extra": {
      "eas": {
        "projectId": "1b9df205-27f5-4724-9981-c12d4a4b700b"
      }
    },
    "owner": "octopus67",
    "newArchEnabled": false
  }
}
