# App Configuration
APP_NAME=Repwise
DEBUG=true

# Database (SQLite for local development)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Trusted hosts (comma-separated, override in prod)
# ALLOWED_HOSTS=["your-app.railway.app"]

# AWS SES Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
SES_SENDER_EMAIL=noreply@your-domain.com
SES_REGION=us-east-1

# JWT (token signing — min 32 chars in production)
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple OAuth
APPLE_CLIENT_ID=com.your-app.bundle-id

# USDA FoodData Central
USDA_API_KEY=DEMO_KEY

# R2 Cloud Storage
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_BUCKET_NAME=repwise-uploads

# CDN
CDN_BASE_URL=https://cdn.repwise.app

# Observability
SENTRY_DSN=<your-sentry-dsn>

# Push Notifications
EXPO_ACCESS_TOKEN=
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_AUTH_KEY_PATH=

# Rate Limiting
RATE_LIMIT_RPM=100
LOGIN_RATE_LIMIT_THRESHOLD=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900

# Production Hosts
ALLOWED_HOSTS=["your-app.railway.app"]
CORS_ORIGINS=["https://your-app.com"]

# Redis (required in production for rate limiting, optional in dev)
REDIS_URL=redis://localhost:6379/0

# RevenueCat (iOS IAP + Google Play Billing)
REVENUECAT_API_KEY=your-revenuecat-api-key
REVENUECAT_WEBHOOK_AUTH_KEY=your-revenuecat-webhook-auth-key
REVENUECAT_API_URL=https://api.revenuecat.com/v1

# PostHog (analytics + feature flags)
POSTHOG_PROJECT_API_KEY=<your-posthog-key>
POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat Frontend SDK Keys (Expo public vars, inlined at build time)
EXPO_PUBLIC_RC_IOS_KEY=<your-revenuecat-ios-key>
EXPO_PUBLIC_RC_ANDROID_KEY=goog_your-revenuecat-android-key
